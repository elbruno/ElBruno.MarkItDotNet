@page "/"
@inject HostedAgentClient AgentClient

<PageTitle>MarkItDotNet – Foundry Agent Demo</PageTitle>

<div class="container">
    <h1>MarkItDotNet Foundry Agent</h1>
    <p class="subtitle">
        Upload a file and convert it to Markdown via Aspire service discovery.
    </p>

    <div class="panel">
        <label>Configuration</label>
        <small>
            By default, this sample uses Aspire service discovery to reach the agent at <strong>@AgentClient.AgentServiceName</strong>.
        </small>

        <div style="margin-top: 12px; margin-bottom: 12px;">
            <input type="checkbox" id="useCustomUrl" @bind="_useCustomUrl" />
            <label for="useCustomUrl" style="display: inline; margin-left: 8px;">
                Use custom URL
            </label>
        </div>

        @if (_useCustomUrl)
        {
            <label for="customUrl">Custom agent URL</label>
            <input id="customUrl" type="text" @bind="_customUrl" placeholder="e.g., http://localhost:8088" />
            <small>
                Leave blank to fall back to service discovery.
            </small>
        }

        <label for="fileInput">File to convert</label>
        <InputFile id="fileInput" OnChange="OnFileSelected" />

        @if (_selectedFile is not null)
        {
            <p class="file-info">
                Selected: <strong>@_selectedFile.Name</strong>
                &nbsp;(@FormatBytes(_selectedFile.Size))
            </p>
        }

        <button @onclick="ConvertAsync" disabled="@_isBusy">
            @(_isBusy ? "Converting…" : "Convert to Markdown")
        </button>
    </div>

    @if (!string.IsNullOrWhiteSpace(_statusMessage))
    {
        <div class="status @(_isSuccess ? "ok" : "error")">@_statusMessage</div>
    }

    @if (!string.IsNullOrWhiteSpace(_markdownResult))
    {
        <div class="result">
            <h2>Result</h2>
            <pre>@_markdownResult</pre>
        </div>
    }
</div>

@code {
    private IBrowserFile? _selectedFile;
    private bool _isBusy;
    private bool _isSuccess;
    private string? _statusMessage;
    private string? _markdownResult;
    private bool _useCustomUrl;
    private string _customUrl = string.Empty;


    private void OnFileSelected(InputFileChangeEventArgs e)
    {
        _selectedFile = e.File;
        _statusMessage = null;
        _markdownResult = null;
    }

    private async Task ConvertAsync()
    {
        if (_selectedFile is null)
        {
            _isSuccess = false;
            _statusMessage = "Please select a file first.";
            return;
        }

        _isBusy = true;
        _statusMessage = "Sending file to the agent…";
        _markdownResult = null;

        try
        {
            var customUrl = _useCustomUrl && !string.IsNullOrWhiteSpace(_customUrl) ? _customUrl : null;
            var result = await AgentClient.ConvertAsync(_selectedFile, customUrl, CancellationToken.None);
            _isSuccess = result.Success;
            _statusMessage = result.Success
                ? $"Converted successfully ({result.FileName}{result.Extension})."
                : result.ErrorMessage;
            _markdownResult = result.Markdown;
        }
        finally
        {
            _isBusy = false;
        }
    }

    private static string FormatBytes(long bytes) => bytes switch
    {
        >= 1024 * 1024 => $"{bytes / (1024.0 * 1024.0):F2} MB",
        >= 1024 => $"{bytes / 1024.0:F2} KB",
        _ => $"{bytes} B"
    };
}
