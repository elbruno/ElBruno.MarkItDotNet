{
  "IngestionWorkflow": {
    "InputPath": "input",
    "OutputPath": "output",
    "Recursive": true,
    "MaxDepth": 3,
    "IncludePatterns": [
      "*.txt",
      "*.json",
      "*.html"
    ],
    "MaxFileSizeBytes": 50000000,
    "PassThreshold": 0.7,
    "DryRun": false,
    "SeedInput": true,
    "ChunkingStrategy": "paragraph",
    "ChunkSize": 512,
    "ChunkOverlap": 50,
    "AzureSearch": {
      "Enabled": false,
      "Endpoint": "",
      "IndexName": "",
      "ApiKey": "",
      "BatchSize": 100,
      "VectorDimensions": 1536,
      "CreateIndexIfMissing": true
    }
  }
}
