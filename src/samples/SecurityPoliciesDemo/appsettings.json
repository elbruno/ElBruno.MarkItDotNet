{
  "SecurityPoliciesDemo": {
    "OutputPath": "output",
    "AuditLogPath": "output/security-audit.jsonl",
    "DryRun": false,
    "MaxIssues": 20,
    "DetectJavaScriptLinks": true,
    "DetectSecretLikeTokens": true,
    "DetectControlCharacters": true,
    "MaxContentLength": 20000,
    "EnablePiiRedaction": true,
    "RedactionMask": "[REDACTED]",
    "DenyKeywords": [
      "confidential",
      "secret"
    ]
  }
}
